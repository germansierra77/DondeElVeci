<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>COMPRA</title>
    <link rel="stylesheet" href="../ccs/fontawesome.css">
    <link rel="stylesheet" href="../ccs/compra?v=1.4">
    <script type="module" src="../js/main.js"></script>
</head>
<body>
    <div class="contenedor">
        <div id="header"><div id="menualterno"></div>
            <div id="letreroapp">
                <div class="elemento">APP DONDE EL VECI</div>
        </div>
        <div id="idcliente">
                <div class="idcliente"> 
                    <label for="idcliente" class="form-label">IDCLIENTE</label>
                    <input type="text" class="form-control" id="idcliente" placeholder="357894">
        </div>
        </div>
        <div id="contenido">   
            <div class="botoneslistado" role="group" aria-label="Basic mixed styles example">
                <button type="button" class="btn-listado">AGREGAR</button>
                <button type="button" class="btn-listado">BUSCAR</button>
                <button type="button" class="btn-listado">ELIMINAR</button>
            </div>
            <div class="listado"> 
                <table>
                    <tr>
                        <th>PRODUCTO</th>
                        <th>MEDIDA</th>
                        <th>PRECIO</th>
                        <th>CANTIDAD</th>
                    </tr>
                    <tr>
                        <td>Arroz</td>
                        <td>Libra</td>
                        <td>$3500</td>
                        <td>
                            <div class="form-floating mb-3">
                            <input type="number" class="form-control" id="casillascantidad" placeholder="cantidad">
                            <label for="floatingInput"></label>
                        </div></td>
                    </tr>
                    <tr>
                        <td>Papa criolla</td>
                        <td>Libra</td>
                        <td>$1200</td>
                        <td><div class="form-floating mb-3">
                            <input type="number" class="form-control" id="casillascantidad" placeholder="cantidad">
                            <label for="floatingInput"></label>
                        </div></td>
                    </tr>
                    <tr>
                        <td>Frijol bola roja</td>
                        <td>Libra</td>
                        <td>$5500</td>
                        <td><div class="form-floating mb-3">
                            <input type="number" class="form-control" id="casillascantidad" placeholder="cantidad">
                            <label for="floatingInput"></label>
                        </div></td>
                    </tr>
                    <tr>
                        <td>Aceite de oliva</td>
                        <td>Frasco*500ml</td>
                        <td>$32000</td>
                        <td><div class="form-floating mb-3">
                            <input type="number" class="form-control" id="casillascantidad" placeholder="cantidad">
                            <label for="floatingInput"></label>
                        </div></td>
                    </tr>
                    <tr>
                        <td>Gaseosa coca cola</td>
                        <td>Unidad*200ml</td>
                        <td>$8000</td>
                        <td><div class="form-floating mb-3">
                            <input type="number" class="form-control" id="casillascantidad" placeholder="cantidad">
                            <label for="floatingInput"></label>
                        </div></td>
                    </tr>
                </table>
            </div>
        </div>
        <div id="footer">
            <div class="button">
                <button type="button"  id="btnvolvermenu">VOLVER</button>
                <button type="button"  id="btncomprar">COMPRAR</button>

                <div class="contendor-toast" id="contenedor-toast">
                    <div class="toast exitosa autoCierre" id="1">
                        <div class="contenidos">
                            <div class="icono">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M3 14.5A1.5 1.5 0 0 1 1.5 13V3A1.5 1.5 0 0 1 3 1.5h8a.5.5 0 0 1 0 1H3a.5.5 0 0 0-.5.5v10a.5.5 0 0 0 .5.5h10a.5.5 0 0 0 .5-.5V8a.5.5 0 0 1 1 0v5a1.5 1.5 0 0 1-1.5 1.5z"/>
                                    <path d="m8.354 10.354 7-7a.5.5 0 0 0-.708-.708L8 9.293 5.354 6.646a.5.5 0 1 0-.708.708l3 3a.5.5 0 0 0 .708 0"/>
                                  </svg>
                                </div>
                            <div class="texto">
                                <p class="titulo">COMPRA EXITOSA</p>
                                <p class="descripcion">TRANSACCION PROCESADA,ESTE DINERO SERA DESCONTANDO
                                    DE TU SALDO ACTUAL</p>
                            </div>
                        </div>
                        <button class="btncerrar">
                            <div class="icono">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M14 1a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1zM2 0a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2z"/>
                                    <path d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708"/>
                                  </svg>
                            </div>
                        </button>
                    </div>
                    <div class="toast fallida autoCierre" id="2">
                        <div class="contenidos">
                            <div class="icono">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0M8 4a.905.905 0 0 0-.9.995l.35 3.507a.552.552 0 0 0 1.1 0l.35-3.507A.905.905 0 0 0 8 4m.002 6a1 1 0 1 0 0 2 1 1 0 0 0 0-2"/>
                                  </svg>
                            </div>
                            <div class="texto">
                                <p class="titulo">COMPRA FALLIDA</p>
                                <p class="descripcion">TRANSACCION INCOMPLETA,POR FAVOR REVISA LOS DATOS
                                    INGRESADOS
                                </p>
                            </div>
                        </div>
                        <button class="btncerrar">
                            <div class="icono">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M14 1a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1zM2 0a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2z"/>
                                    <path d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708"/>
                                  </svg>
                            </div>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
